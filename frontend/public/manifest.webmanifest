{
  "id": "/",
  "name": "Reconnect AI - Intelligent Network OS",
  "short_name": "Reconnect AI",
  "description": "Network Intelligence CRM com grafo operacional, timeline e IA de relacionamento.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "any",
  "background_color": "#080b12",
