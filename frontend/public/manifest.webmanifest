      "icons": [{ "src": "/icons/maskable-icon.svg", "sizes": "512x512", "type": "image/svg+xml" }]
    }
  ],
  "screenshots": [
    {
      "src": "/icons/maskable-icon.svg",
      "sizes": "512x512",
